\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Structure of Multiband} | On the head, custom cosine collectors (red) and the reference collector (purple). The signal is transmitted through slots 0 (incident channel) and 7 (reflected) of the wheel; at any step $n$, the wheel rotates of one slot counter-clockwise. Simultaneous acquisition on reflected and incident channels are possible at 500 (green), 800 (red), 1050 (pale red), and \qty {1300}{\nano \meter } (light brown), thanks to duplicated filters (2-9, 3-10, 4-11 and 5-12 respectively). Dual photodiodes are composed of two stacked Si (purple) and InGaAs (pink) photodiodes. Modified after \blx@tocontentsinit {0}\cite {arioliDynamicsSnowGrain2023}.}}{10}{figure.caption.3}\protected@file@percent }
\newlabel{fig:mbscheme}{{3}{10}{\textbf {Structure of Multiband} | On the head, custom cosine collectors (red) and the reference collector (purple). The signal is transmitted through slots 0 (incident channel) and 7 (reflected) of the wheel; at any step $n$, the wheel rotates of one slot counter-clockwise. Simultaneous acquisition on reflected and incident channels are possible at 500 (green), 800 (red), 1050 (pale red), and \qty {1300}{\nano \meter } (light brown), thanks to duplicated filters (2-9, 3-10, 4-11 and 5-12 respectively). Dual photodiodes are composed of two stacked Si (purple) and InGaAs (pink) photodiodes. Modified after \cite {arioliDynamicsSnowGrain2023}}{figure.caption.3}{}}
