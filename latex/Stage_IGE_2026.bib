  urldate = {2026-01-06},
  abstract = {In physics, absorption cross-section is a measure of the probability of an absorption process. More generally, the term cross-section is used in physics to quantify the probability of a certain particle-particle interaction, e.g., scattering, electromagnetic absorption, etc. (Note that light in this context is described as consisting of particles, i.e., photons.) A typical absorption cross-section has units of cm2⋅molecule−1. In honor of the fundamental contribution of Maria Goeppert Mayer to this area, the unit for the two-photon absorption cross section is named the "GM". One GM is 10−50 cm4⋅s⋅photon−1. In the context of ozone shielding of ultraviolet light, absorption cross section is the ability of a molecule to absorb a photon of a particular wavelength and polarization. Analogously, in the context of nuclear engineering, it refers to the probability of a particle (usually a neutron) being absorbed by a nucleus.  Although the units are given as an area, it does not refer to an actual size area, at least partially because the density or state of the target molecule will affect the probability of absorption. Quantitatively, the number                         d         N                 \{\textbackslash displaystyle dN\}     of photons absorbed, between the points                         x                 \{\textbackslash displaystyle x\}     and                         x         +         d         x                 \{\textbackslash displaystyle x+dx\}     along the path of a beam is the product of the number                         N                 \{\textbackslash displaystyle N\}     of photons penetrating to depth                         x                 \{\textbackslash displaystyle x\}     times the number                         n                 \{\textbackslash displaystyle n\}     of absorbing molecules per unit volume times the absorption cross section                         σ                 \{\textbackslash displaystyle \textbackslash sigma \}    :                                                               d               N                                         d               x                                          =         −         N         n         σ                 \{\textbackslash displaystyle \{\textbackslash frac \{dN\}\{dx\}\}=-Nn\textbackslash sigma \}    . The absorption cross-section is closely related to molar absorptivity                         ε                 \{\textbackslash displaystyle \textbackslash varepsilon \}     and mass absorption coefficient.                        σ         =                                                ln               ⁡               (               10               )               ×                                10                                    3                                                                         N                                A                                                         ×         ε                 \{\textbackslash displaystyle \textbackslash sigma =\{\textbackslash frac \{\textbackslash ln(10)\textbackslash times 10\textasciicircum\{3\}\}\{N\_\{\textbackslash text\{A\}\}\}\}\textbackslash times \textbackslash varepsilon \}    For a given particle and its energy, the absorption cross-section of the target material can be calculated from mass absorption coefficient using:                        σ         =         (         μ                    /                  ρ         )                    m                        a                                        /                             N                        A                                     \{\textbackslash displaystyle \textbackslash sigma =(\textbackslash mu /\textbackslash rho )m\_\{\textbackslash text\{a\}\}/N\_\{\textbackslash text\{A\}\}\}    where:                         μ                    /                  ρ                 \{\textbackslash displaystyle \textbackslash mu /\textbackslash rho \}     is the mass absorption coefficient                                   m                        a                                     \{\textbackslash displaystyle m\_\{\textbackslash text\{a\}\}\}     is the molar mass in g/mol                                   N                        A                                     \{\textbackslash displaystyle N\_\{\textbackslash text\{A\}\}\}     is Avogadro constant This is also commonly expressed as:                        σ         =         α                    /                  n                 \{\textbackslash displaystyle \textbackslash sigma =\textbackslash alpha /n\}    where:                         α                 \{\textbackslash displaystyle \textbackslash alpha \}     is the absorption coefficient                        n                 \{\textbackslash displaystyle n\}     is the atomic number density},
  langid = {english},
  annotation = {Page Version ID: 1319054202},
  file = {/home/pietroperrone/Zotero/storage/GQUU8XHG/index.html}
}

