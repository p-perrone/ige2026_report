@article{frezzottiSnowMegadunesAntarctica2002,
  title = {Snow Megadunes in {{Antarctica}}: {{Sedimentary}} Structure and Genesis},
  author = {Frezzotti, M. and Gandolfi, S. and Urbini, S.},
