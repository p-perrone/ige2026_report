@article{aokiDevelopmentHandheldIntegrating2025,
  title = {Development of a Handheld Integrating Sphere Snow Grain Sizer ({{HISSGraS}})},
  author = {Aoki, Teruo and Hachikubo, Akihiro and Nishimura, Motoshi and Hori, Masahiro and Niwano, Masashi and Tanikawa, Tomonori and Sugiura, Konosuke and Inoue, Ryo and Yamaguchi, Satoru and Matoba, Sumito and Shimada, Rigen and Ishimoto, Hiroshi and Gallet, Jean-Charles},
