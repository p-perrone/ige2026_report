@article{colbeckOverviewSeasonalSnow1982,
  title = {An Overview of Seasonal Snow Metamorphism},
  author = {Colbeck, S. C.},
  date = {1982-02-01},
  journaltitle = {Reviews of Geophysics},
  shortjournal = {Reviews of Geophysics},
  volume = {20},
  number = {1},
  pages = {45--61},
  publisher = {John Wiley \& Sons, Ltd},
  issn = {8755-1209},
  doi = {10.1029/RG020i001p00045},
  url = {https://doi.org/10.1029/RG020i001p00045},
  urldate = {2026-05-15},
  abstract = {The grains in seasonal snow undergo rapid and radical transformations in size, shape, and cohesion. These grain characteristics affect all of the basic properties of snow. Snow is characterized as either wet or dry depending on the presence of liquid water. Wet snow is markedly different at low and high liquid contents. Dry snow is characterized as either an equilibrium form or a kinetic growth form; that is, it is either well rounded or faceted. Of course, many snow grains display either transitional features between two of these categories or features which arise from other processes. Snow is classified depending on the dominant processes of its metamorphism.}
}

@article{comiso2008_seaice,
  title = {Trends in the Sea Ice Cover Using Enhanced and Compatible {{AMSR-E}}, {{SSM}}/{{I}}, and {{SMMR}} Data},
  author = {Comiso, Josefino C. and Nishio, Fumihiko},
  date = {2008},
  journaltitle = {Journal of Geophysical Research: Oceans},
  volume = {113},
  number = {C2},
  eprint = {https://agupubs.onlinelibrary.wiley.com/doi/pdf/10.1029/2007JC004257},
  doi = {10.1029/2007JC004257},
  url = {https://agupubs.onlinelibrary.wiley.com/doi/abs/10.1029/2007JC004257},
  abstract = {Arguably, the most remarkable manifestation of change in the polar regions is the rapid decline in the Arctic perennial ice cover. Changes in the global sea ice cover, however, have been more modest, being only slightly negative in the Northern Hemisphere and even slightly positive in the Southern Hemisphere, the significance of which has not been adequately assessed because of unknown errors in the satellite historical data. Recent Advanced Microwave Scanning Radiometer (AMSR-E) high-resolution data are used as the baseline for generating an enhanced sea ice data set used in this study. Brightness temperature data from historical Special Scanning Microwave Imager (SSM/I) and Scanning Multichannel Microwave Radiometer (SMMR) sensors were normalized to be consistent with those from AMSR-E, and sea ice parameters were derived from all three data sets using the same algorithm for optimum consistency and accuracy. A small bias in sea ice extent is observed between AMSR-E and SSM/I data which, if uncorrected, causes an error of 0.62\%/decade in the Arctic and 0.26\%/decade in the Antarctic. Similar corrections are not needed in trend estimates of sea ice area. Biases due to seasonal changes in the accuracy of ice edge determinations, especially during melt periods, were also evaluated, and impacts on the trend results appear to be small. When updated to 2006, the trends in ice extent and area in the Arctic are now slightly more negative at −3.4 ± 0.2 and −4.0 ± 0.2\% per decade, respectively, while the corresponding trends in the Antarctic remains slight but positive at 0.9 ± 0.2 and 1.7 ± 0.3\% per decade.},
  keywords = {Antarctic,Arctic,climate,remote sensing,sea ice,trends}
}

