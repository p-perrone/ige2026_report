@article{croninHowWellWe2023,
  title = {How {{Well}} Do {{We Understand}} the {{Planck Feedback}}?},
  author = {Cronin, Timothy W. and Dutta, Ishir},
  date = {2023-07-01},
  journaltitle = {Journal of Advances in Modeling Earth Systems},
