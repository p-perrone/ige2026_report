@article{courvilleMegadunes2007,
  title = {Impacts of an Accumulation Hiatus on the Physical Properties of Firn at a Low-Accumulation Polar Site},
  author = {Courville, Z. R. and Albert, M. R. and Fahnestock, M. A. and Cathles IV, L. M. and Shuman, C. A.},
